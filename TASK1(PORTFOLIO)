    <section class="container bg-light text-center">
        <h2>Resume</h2>
        <p>Want to see my full professional history?</p>
        <a href="resume1.png" class="btn" download>Download PDF Resume</a>
    </section>

    <section id="contact" class="container text-center">
        <h2>Get In Touch</h2>
        <p>Feel free to reach out for collaborations or just a friendly chat!</p>
        <p>Email: <a href="mailto:kumarsinghprince800@gmail.com">kumarsinghprince800@gmail.com</a></p>
        <p>Phone: 9234807866</p>
    </section>

    <footer>
        <p>&copy; 2026 Prince Kumar Singh. All rights reserved.</p>
    </footer>

</body>
</html>
